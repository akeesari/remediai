# Postgres
POSTGRES_PASSWORD=change_me_locally

# Optional host port overrides when default local ports are already in use
LOCAL_POSTGRES_PORT=5432
LOCAL_REDIS_PORT=6379
LOCAL_SERVICEBUS_PORT=5672
LOCAL_API_PORT=8000
LOCAL_DASHBOARD_PORT=3000

# Azure OpenAI (optional for local startup, required for full agent pipeline)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure DevOps (optional for local startup)
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# Azure AI Search (optional for local startup)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=

# Service Bus namespace (defaults to emulator)
AZURE_SERVICEBUS_NAMESPACE=localhost
AZURE_SERVICEBUS_CONNECTION_STRING=

# ACR / image tag for optional registry-driven deployment
ACR_LOGIN_SERVER=aitenant.azurecr.io
ACR_IMAGE_TAG=latest
