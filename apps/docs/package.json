{
  "name": "remediai-docs",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "sync-content": "python3 ../../scripts/sync_docs_site.py",
    "docusaurus": "docusaurus",
    "start": "npm run sync-content && docusaurus start",
    "build": "npm run sync-content && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "npm run sync-content && docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "npm run sync-content && tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@docusaurus/theme-mermaid": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.44.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@tsconfig/docusaurus": "^2.0.0",
    "typescript": "~5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
