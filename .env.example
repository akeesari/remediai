# ---------------------------------------------------------------
# RemediAI — Environment Variables
# Copy this file to .env for local development and Docker Compose.
# NEVER commit .env — it is ignored by git.
# All production secrets are managed via Azure Key Vault.
# ---------------------------------------------------------------

# --- Local Docker Compose overrides ----------------------------
# Change these only when the default ports are already in use.
LOCAL_POSTGRES_PORT=5432
LOCAL_REDIS_PORT=6379
LOCAL_API_PORT=8000
LOCAL_DASHBOARD_PORT=3000
LOCAL_DOCS_PORT=3001

# Enable local-only endpoints and the incident poller used by the log bridge.
LOCAL_MODE=true
BRIDGE_CONTAINERS=api,worker,dashboard

# --- Azure Identity -------------------------------------------
# Leave blank when using Managed Identity (AKS / local az login).
# Set only when using a service principal for local dev.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Azure Monitor / Application Insights ---------------------
AZURE_MONITOR_WORKSPACE_ID=
AZURE_MONITOR_APP_INSIGHTS_RESOURCE_ID=

# --- Azure OpenAI ---------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Azure AI Search ------------------------------------------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=remediai-rag
AZURE_SEARCH_API_KEY=
SEARCH_INDEX_NAME=remediai-incidents
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DEPLOYMENT=
ADO_SOURCE_REPO=
ADO_SOURCE_PATH_PREFIX=src/

# --- Azure Key Vault ------------------------------------------
AZURE_KEYVAULT_URL=

# --- Azure DevOps ---------------------------------------------
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_REPOSITORY=
AZURE_DEVOPS_BRANCH=main
AZURE_DEVOPS_PAT=

# --- PostgreSQL -----------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=remediai
POSTGRES_USER=remediai
POSTGRES_PASSWORD=change_me_locally

# --- Redis ----------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Application ----------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
CORRELATION_ID_HEADER=X-Correlation-ID

# --- Ingestion ------------------------------------------------
INGESTION_POLL_INTERVAL_SECONDS=60
INGESTION_LOOKBACK_MINUTES=10

# --- Local incident polling -----------------------------------
LOCAL_INCIDENT_POLL_INTERVAL_SECONDS=10
